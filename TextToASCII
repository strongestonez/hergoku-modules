                            "args": (text.upper(), effect_name)
                        }
                    ],
                    [
                        {
                            "text": "❌ Закрыть",
                            "action": "close"
                        }
                    ]
                ]
            })
        
        return results

    async def _start_animation_inline(self, call, text: str, effect: str):
        """Запускает анимацию из inline режима"""
        # Показываем статус
        await call.edit(f"<code>🎬 Запуск анимации...</code>")
        await asyncio.sleep(0.5)
        
        try:
            if effect == 'all':
                await self._animate_all_chars(call, text, 'wave')
            else:
                for char in text:
                    ascii_lines = self._get_char_art(char)
                    await self._animate_single_char(call, ascii_lines, effect)
                    await asyncio.sleep(0.3)
            
            # После завершения показываем кнопки
            await call.edit(
                text=(
                    f"<b>✨ Анимация завершена!</b>\n\n"
                    f"<blockquote><b>📝 Текст:</b> {text}</blockquote>\n"
                    f"<blockquote><b>🎨 Эффект:</b> {effect.upper()}</blockquote>\n\n"
                    f"<i>💡 Нажмите кнопку для повтора</i>"
                ),
                reply_markup=[
                    [
                        {
                            "text": "🔄 Перезапустить анимацию",
                            "callback": self._start_animation_inline,
                            "args": (text, effect)
                        }
                    ],
                    [
                        {
                            "text": "🎨 Выбрать другой эффект",
                            "callback": self._show_effects_menu,
                            "args": (text,)
                        }
                    ],
                    [
                        {
                            "text": "❌ Закрыть",
                            "action": "close"
                        }
                    ]
                ]
            )
        except Exception as e:
            await call.edit(f"❌ Ошибка: {str(e)}")

