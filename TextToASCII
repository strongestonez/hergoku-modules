                except:
                    pass
            
            # После завершения показываем кнопки
            await call.edit(
                text=(
                    f"<pre>{self._format_for_telegram(combined_lines)}</pre>\n\n"
                    f"<b>✨ Анимация завершена!</b>\n\n"
                    f"<blockquote><b>📝 Текст:</b> {text}</blockquote>\n\n"
                    f"<i>💡 Нажмите кнопку для повтора</i>"
                ),
                reply_markup=[
