        """Inline handler для @bot текст - показывает варианты с эффектами"""
        text = query.args
        
        if not text:
            return await query.e400()
        
        # Список всех эффектов с описаниями
        effects = [
            ("fade", "Плавное появление", "⚡"),
            ("line", "Построчное появление", "📊"),
            ("left", "Слева направо", "➡️"),
            ("center", "От центра к краям", "🎯"),
            ("wave", "Волновой эффект", "🌊"),
            ("random", "Случайные пиксели", "🎲"),
            ("all", "Все буквы сразу", "⚡")
        ]
        
        # Создаём результаты для каждого эффекта
        results = []
        for effect_name, effect_desc, emoji in effects:
            results.append({
                "title": f"{emoji} {effect_desc}",
                "description": f"Анимация текста '{text}' с эффектом {effect_name}",
                "message": text.upper(),
