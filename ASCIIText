            frames = 20
            delay = 0.08
            
            for frame in range(frames + 1):
                if not self.is_running:
                    break
                    
                progress = frame / frames
                
                if effect == 'fade':
                    animated_lines = self._animate_fade_in(combined_lines, progress)
                elif effect == 'line':
                    animated_lines = self._animate_line_by_line(combined_lines, progress)
                elif effect == 'left':
                    animated_lines = self._animate_left_to_right(combined_lines, progress)
                elif effect == 'center':
                    animated_lines = self._animate_center_out(combined_lines, progress)
                elif effect == 'wave':
                    animated_lines = self._animate_wave(combined_lines, progress, frame)
                elif effect == 'random':
                    animated_lines = self._animate_random_dots(combined_lines, progress, 42)
                else:
                    animated_lines = combined_lines
                
                formatted_art = self._format_for_telegram(animated_lines)
                try:
                    await msg.edit(f"<pre>{formatted_art}</pre>")
                    await asyncio.sleep(delay)
                except:
                    pass
            
            # После завершения показываем кнопку для перезапуска
            await asyncio.sleep(0.5)
            await msg.edit(
                f"<b>✨ Анимация завершена!</b>\n"
                f"<i>Текст: {text} | Эффект: {effect.upper()}</i>",
                reply_markup=self._create_restart_button()
            )
        except Exception as e:
            await msg.edit(f"❌ Ошибка: {str(e)}")
        finally:
            self.is_running = False

    async def asciistopagecmd(self, message):
        """Команда: .asciistopage
        
        Останавливает текущую анимацию.
        """
        if self.is_running:
            self.is_running = False
            await utils.answer(message, "⏹ Анимация остановлена.")
        else:
            await utils.answer(message, "ℹ️ Анимация не запущена.")

